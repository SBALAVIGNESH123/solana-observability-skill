{
  "name": "solana-observability-skill",
  "version": "2.0.0",
  "description": "Production-grade observability for Solana programs, validators, and infrastructure",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start:exporter": "tsx examples/rpc-health-monitor.ts",
    "start:security": "tsx examples/security-monitor.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint examples/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "smoke-test": "bash scripts/smoke-test.sh",
    "deploy": "cd deploy && docker compose up -d",
    "deploy:down": "cd deploy && docker compose down"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@solana/web3.js": "^1.95.0",
    "@triton-one/yellowstone-grpc": "^1.3.0",
    "pino": "^9.3.0",
    "prom-client": "^15.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.6.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "author": "SBALAVIGNESH123",
  "repository": {
    "type": "git",
    "url": "https://github.com/SBALAVIGNESH123/solana-observability-skill.git"
  },
  "keywords": [
    "solana",
    "observability",
    "prometheus",
    "grafana",
    "monitoring",
    "geyser",
    "yellowstone",
    "opentelemetry"
  ]
}
