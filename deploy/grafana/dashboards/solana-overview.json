{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "RPC Health Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{
        "expr": "solana_rpc_health_status",
        "legendFormat": "{{ endpoint }}"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      }
    },
    {
      "title": "RPC Request Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(solana_rpc_request_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 {{ endpoint }}"
      }],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2, "fillOpacity": 10 } } }
    },
    {
      "title": "Transaction Landing Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{
        "expr": "solana_tx_landing_rate_percent",
        "legendFormat": "Landing Rate"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 70 }, { "color": "green", "value": 90 }] }
        }
      }
    },
    {
      "title": "Transactions Sent vs Landed",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "rate(solana_tx_sent_total[5m])", "legendFormat": "Sent" },
        { "expr": "rate(solana_tx_landed_total[5m])", "legendFormat": "Landed" },
        { "expr": "rate(solana_tx_errors_total[5m])", "legendFormat": "Errors" }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 20 } } }
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{
        "expr": "solana_rpc_circuit_breaker_state",
        "legendFormat": "{{ endpoint }}"
      }],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "HALF-OPEN", "color": "orange" }, "2": { "text": "OPEN", "color": "red" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Security Alerts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{
        "expr": "increase(solana_security_authority_changes_total[1h])",
        "legendFormat": "Authority Changes (1h)"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      }
    },
    {
      "title": "Validator Skip Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "solana_validator_skip_rate",
        "legendFormat": "{{ identity }}"
      }],
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "red", "value": 0.2 }] } } }
    },
    {
      "title": "SLO Error Budget Remaining",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "1 - (rate(solana_tx_errors_total[1h]) / rate(solana_tx_sent_total[1h])) / (1 - 0.995)",
        "legendFormat": "Error Budget"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.25 }, { "color": "green", "value": 0.5 }] }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["solana", "observability", "rpc", "validator"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Solana Observability Overview",
  "uid": "solana-obs-overview",
  "version": 1,
  "weekStart": ""
}
